{
    "main": "dist/_worker.js/index.js",
    "name": "sonus",
    "compatibility_date": "2025-12-01",
    "compatibility_flags": [
        "nodejs_compat",
        "global_fetch_strictly_public"
    ],
    "assets": {
        "binding": "ASSETS",
        "directory": "./dist"
    },
    "observability": {
        "enabled": false
    },
    "env": {
        "froglight": {
            "vars": {
                "DEFAULT_WEBSOCKET_URL": "wss://sonus.froglight.net/api"
            }
        },
        "froglight-test": {
            "vars": {
                "DEFAULT_WEBSOCKET_URL": "wss://sonus.froglight.eu/api"
            }
        }
    }
}
