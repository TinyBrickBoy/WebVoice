{
    "main": "@astrojs/cloudflare/entrypoints/server",
    "name": "sonus",
    "compatibility_date": "2025-12-01",
    "compatibility_flags": [
        "nodejs_compat",
        "global_fetch_strictly_public"
    ],
    "assets": {
        "binding": "ASSETS",
        "directory": "./dist"
    },
    "observability": {
        "enabled": false
    },
    "env": {
        "froglight": {
            "vars": {
                "ASTRO_SITE": "https://audio.froglight.eu/",
                "DEFAULT_WEBSOCKET_URL": "wss://sonus.froglight.net/api",
                "ICE_SERVER": "stun:stun.froglight.net:3478"
            }
        },
        "froglight-test": {
            "vars": {
                "ASTRO_SITE": "https://daudio.froglight.eu/",
                "DEFAULT_WEBSOCKET_URL": "wss://sonus.froglight.eu/api",
                "ICE_SERVER": "stun:stun.froglight.net:3478"
            }
        }
    }
}
