---
import Layout from "../../layouts/Layout.astro";
import VoiceStateProvider from "../../components/VoiceStateProvider";
import {constructSocketUrl, TOKEN_LENGTH} from "../../scripts/util/util.ts";
import ErrorPage from "../../components/base/ErrorPage.astro";

export const prerender = false;
const {token} = Astro.params;

if (!token || token.length !== TOKEN_LENGTH) {
    Astro.response.status = 404;
}
---

<Layout>
    {token && token.length === TOKEN_LENGTH ?
        <VoiceStateProvider client:only socketUrl={constructSocketUrl(token)} token={token}/> :
        <ErrorPage error={404}/>
    }
</Layout>
