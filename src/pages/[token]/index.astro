---
import Layout from "../../layouts/Layout.astro";
import VoiceStateProvider from "../../components/VoiceStateProvider";
import {constructSocketUrl, TOKEN_LENGTH} from "../../scripts/util/util.ts";
import ErrorPage from "../../components/base/ErrorPage.astro";
import {DEFAULT_WEBSOCKET_URL} from "astro:env/client";

export const prerender = false;
const {token} = Astro.params;
const apiUrl = Astro.url.searchParams.get("api") ?? DEFAULT_WEBSOCKET_URL;

let socketUrl = null
if (!token || !apiUrl || token.length !== TOKEN_LENGTH) {
    Astro.response.status = 404;
} else {
    try {
        socketUrl = constructSocketUrl(apiUrl, token);
    } catch (error) {
        Astro.response.status = 400;
    }
}
---

<Layout>
    {token && socketUrl && token.length === TOKEN_LENGTH ?
        <VoiceStateProvider client:only="preact" socketUrl={socketUrl} token={token}/> :
        <ErrorPage error={Astro.response.status || 500}/>
    }
</Layout>
